#模板
# ── MySQL ────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=<填写真实密码>
MYSQL_DATABASE=segger_db
MYSQL_CHARSET=utf8mb4

# ── MongoDB ──────────────────────────────
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DATABASE=gmdb
MONGO_AUTH_SOURCE=admin

# ── Pulsar ───────────────────────────────
PULSAR_SERVICE_URL=pulsar://127.0.0.1:6650
PULSAR_TOPIC=persistent://public/default/security_info
PULSAR_SUBSCRIPTION_NAME=data-quality-monitor-sub
PULSAR_RECEIVE_TIMEOUT_MS=5000
PULSAR_COLLECT_WINDOW_SECONDS=30

# ── 日志 ─────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── 监控 ─────────────────────────────────
CHECK_TIMEOUT_SECONDS=60
SNAPSHOT_RETENTION_DAYS=15
CHECK_RESULT_RETENTION_DAYS=90
ACCURACY_DETAIL_RETENTION_DAYS=15
